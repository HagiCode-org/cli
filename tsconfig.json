{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "noEmit": true,
    "types": [
      "node",
      "vitest/globals"
    ]
  },
  "include": [
    "src/cli.ts",
    "src/main.ts",
    "src/commands/**/*.ts",
    "src/runtime/**/*.ts",
    "src/formatters/**/*.ts",
    "src/generated/api/core/**/*.ts",
    "src/generated/api/models/**/*.ts",
    "src/generated/api/services/SessionsService.ts",
    "vite.config.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "tests"
  ]
}
