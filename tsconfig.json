{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "types": [
      "node",
      "vitest/globals"
    ]
  },
  "include": [
    "src/cli.ts",
    "src/main.ts",
    "src/commands/**/*.ts",
    "src/runtime/**/*.ts",
    "src/formatters/**/*.ts",
    "src/generated/api/core/**/*.ts",
    "src/generated/api/models/**/*.ts",
    "src/generated/api/services/SessionsService.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "tests"
  ]
}
